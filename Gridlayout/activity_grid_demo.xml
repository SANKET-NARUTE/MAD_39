<?xml version="1.0" encoding="utf-8"?>
<GridLayout xmlns:android="http://schemas.android.com/apk/res/android"
    style="@style/ScreenContainer"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:alignmentMode="alignMargins"
    android:columnCount="3"
    android:rowCount="3"
    android:useDefaultMargins="true">

    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#E63946" android:gravity="center" android:text="1" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#F77F00" android:gravity="center" android:text="2" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#FCBF49" android:gravity="center" android:text="3" android:textColor="@color/black" android:textSize="@dimen/text_subtitle" />

    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#2A9D8F" android:gravity="center" android:text="4" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#1D3557" android:gravity="center" android:text="5" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#457B9D" android:gravity="center" android:text="6" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />

    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#3A86FF" android:gravity="center" android:text="7" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#8338EC" android:gravity="center" android:text="8" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
    <TextView android:layout_width="0dp" android:layout_height="90dp" android:layout_columnWeight="1" android:background="#FF006E" android:gravity="center" android:text="9" android:textColor="@color/white" android:textSize="@dimen/text_subtitle" />
</GridLayout>
